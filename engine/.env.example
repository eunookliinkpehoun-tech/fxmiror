# ---- MySQL (same DB the Next.js app uses) ----
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=fxmirror
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=fxmirror

# ---- Encryption key: MUST be the SAME value as MT5_ENC_KEY in the Next.js app ----
# Generate once: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MT5_ENC_KEY=PASTE_THE_SAME_BASE64_KEY_HERE

# ---- Master account (its trades get copied to every connected user) ----
MASTER_LOGIN=51234567
MASTER_PASSWORD=your_master_account_password
MASTER_SERVER=ICMarketsSC-Live

# ---- Optional: full path to terminal64.exe (leave blank for default install) ----
# MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# ---- Copy behaviour ----
# COPY_MODE = balance | multiplier | fixed
COPY_MODE=balance
COPY_FIXED_LOT=0.01
COPY_MULTIPLIER=1.0
MIN_LOT=0.01
MAX_LOT=50.0
SYNC_INTERVAL=5
DEVIATION=30
MAGIC=770077
