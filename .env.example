# ============================================================
# FXMIRROR - Next.js web app environment
# Copy this to .env.local and fill in the values.
# ============================================================

# ---- MySQL (your Windows server) ----
# The web app connects to the SAME MySQL database as the Python engine.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=fxmirror
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=fxmirror

# ---- MT5 password encryption key ----
# Must be the EXACT SAME value in engine/.env (MT5_ENC_KEY).
# Generate once with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MT5_ENC_KEY=

# ---- App URL (used for referral links) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
